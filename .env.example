# ─── MongoDB ───────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/studynotes?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ─── OpenRouter (IA Notes + Dashboard) ─────────────────────
OPEN_ROUTER_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Groq (IA Révisions + Visualiseur) ─────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── TTS Service ───────────────────────────────────────────
TTS_SERVICE_URL=http://tts-service:5001

# ─── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
CLIENT_URL=http://localhost:3000

# ─── VAPID Keys (Push Notifications PWA) ───────────────────
# Générer avec : npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:your@email.com
